generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                     String        @id @default(cuid())
  title                  String
  category               String
  subcategoryId          String?
  subcategory            SubCategory?  @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  description            String
  price                  Float?
  sku                    String?
  stock                  Int?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  application            String?
  featureImage           String?
  galleryImages          String[]      @default([])
  overviewSections       String?
  technicalSpecification String?
  overview               String?
  overviewImage          String?

  @@index([subcategoryId])
  @@index([category])
  @@index([category, createdAt])
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  description   String?
  icon          String?
  productCount  Int           @default(0)
  subcategories SubCategory[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SubCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String
  description String?
  icon        String?
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products    Product[]
  productCount Int      @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([categoryId, slug])
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  excerpt   String?
  author    String
  category  String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model PageContent {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  metaDescription String?
  content         String
  sections        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model HomeSection {
  id          String   @id @default(cuid())
  sectionKey  String   @unique
  title       String
  description String?
  content     String
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  data        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MenuItem {
  id        String     @id @default(cuid())
  label     String
  type      String
  target    String
  order     Int
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    MenuItem?  @relation("MenuItemParent", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("MenuItemParent")
}
